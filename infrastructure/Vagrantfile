Vagrant.configure("2") do |config|
    config.vm.box = "bento/ubuntu-24.04"

    K8S_VERSION = "v1.35"
    K8S_PATCH   = "v1.35.0"
    CILIUM_CLI_VERSION = "0.19.1"
    CILIUM_VERSION = "1.19.1"
    POD_CIDR = "10.244.0.0/16"
    MASTER_CPUS = 2
    MASTER_MEMORY = 6144
    WORKER_CPUS = 2
    WORKER_MEMORY = 6144
    ARGOCD_ADMIN_PASSWORD = "qwer1234"

    COMMON_SCRIPT = <<-SHELL
      #!/usr/bin/env bash
      set -euxo pipefail

      export DEBIAN_FRONTEND=noninteractive

      echo "[INFO] Disable swap"
      swapoff -a || true
      sed -i.bak '/\\sswap\\s/s/^/#/' /etc/fstab || true

      echo "[INFO] Load kernel modules"
      cat <<'K8S_CONF' >/etc/modules-load.d/k8s.conf
  overlay
  br_netfilter
K8S_CONF

      modprobe overlay
      modprobe br_netfilter

      echo "[INFO] Apply sysctl settings"
      cat <<'K8S_SYSCTL' >/etc/sysctl.d/k8s.conf
  net.bridge.bridge-nf-call-iptables  = 1
  net.bridge.bridge-nf-call-ip6tables = 1
  net.ipv4.ip_forward                 = 1
K8S_SYSCTL

      sysctl --system

      echo "[INFO] Install base packages"
      apt-get update
      apt-get install -y \
        apt-transport-https \
        ca-certificates \
        curl \
        gpg \
        jq \
        bash-completion \
        apache2-utils

      echo "[INFO] Install containerd"
      apt-get install -y containerd

      mkdir -p /etc/containerd
      if [ ! -f /etc/containerd/config.toml ]; then
        containerd config default >/etc/containerd/config.toml
      fi

      sed -i 's|registry.k8s.io/pause:3.8|registry.k8s.io/pause:3.10.1|g' /etc/containerd/config.toml

      sed -i 's/SystemdCgroup = false/SystemdCgroup = true/g' /etc/containerd/config.toml

      systemctl daemon-reload
      systemctl enable containerd
      systemctl restart containerd

      echo "[INFO] Install Kubernetes packages"
      mkdir -p -m 755 /etc/apt/keyrings
      curl -fsSL https://pkgs.k8s.io/core:/stable:/#{K8S_VERSION}/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

      cat >/etc/apt/sources.list.d/kubernetes.list <<EOF
  deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/#{K8S_VERSION}/deb/ /
EOF

      apt-get update
      apt-get install -y kubelet kubeadm kubectl || { echo "[ERROR] K8s packages installation failed"; exit 1; }
      apt-mark hold kubelet kubeadm kubectl
      systemctl enable kubelet

      echo "[INFO] Configure Kubelet to use eth1 IP"
    NODE_IP=$(ip addr show eth1 | grep "inet " | awk '{print $2}' | cut -d/ -f1)

    cat <<EOF > /etc/default/kubelet
KUBELET_EXTRA_ARGS=--node-ip=$NODE_IP
EOF

    systemctl daemon-reload
    systemctl restart kubelet
    SHELL

    MASTER_SCRIPT = <<-SHELL
      #!/usr/bin/env bash
      set -euxo pipefail

      if [ ! -f /etc/kubernetes/admin.conf ]; then
        echo "[INFO] Initialize Kubernetes control plane"
        kubeadm init \
          --apiserver-advertise-address=192.168.56.10 \
          --pod-network-cidr=#{POD_CIDR} \
          --kubernetes-version=#{K8S_PATCH}
      else
        echo "[INFO] Kubernetes control plane already initialized"
      fi

      echo "[INFO] Configure kubeconfig for vagrant user"
      mkdir -p /home/vagrant/.kube
      cp -f /etc/kubernetes/admin.conf /home/vagrant/.kube/config
      chown -R vagrant:vagrant /home/vagrant/.kube

      export KUBECONFIG=/etc/kubernetes/admin.conf

      echo "[INFO] Wait for API server"
      until kubectl get nodes >/dev/null 2>&1; do
        echo "[INFO] Waiting for API server to respond..."
        sleep 5
      done

      echo "[INFO] Install Cilium CLI if missing"
      if [ ! -x /usr/local/bin/cilium ]; then
        curl -L --fail -o /tmp/cilium-linux-amd64.tar.gz \
          https://github.com/cilium/cilium-cli/releases/download/v#{CILIUM_CLI_VERSION}/cilium-linux-amd64.tar.gz

        tar -xzf /tmp/cilium-linux-amd64.tar.gz -C /usr/local/bin
        chmod +x /usr/local/bin/cilium
        rm -f /tmp/cilium-linux-amd64.tar.gz
      fi

      echo "[INFO] Install Cilium if not installed"
      if ! kubectl -n kube-system get ds cilium >/dev/null 2>&1; then
        cilium install --version #{CILIUM_VERSION} \
          --set ipam.operator.clusterPoolIPv4PodCIDRList="{#{POD_CIDR}}" \
          --set kubeProxyReplacement=true \
          --set k8sServiceHost=192.168.56.10 \
          --set k8sServicePort=6443 \
          --set devices="{eth0,eth1}" \
          --set ingressController.enabled=true \
          --set ingressController.default=true \
          --set ingressController.loadbalancerMode=dedicated \
          --set l2announcements.enabled=true \
          --set lbipam.enabled=true
      fi

      echo "[INFO] Wait for Cilium"
      cilium status --wait

      echo "[INFO] Configure Cilium LB-IPAM pool and L2 announcement policy"
      cat <<'CILIUM_LB_CFG' | kubectl apply -f -
apiVersion: cilium.io/v2alpha1
kind: CiliumLoadBalancerIPPool
metadata:
  name: virtualbox-pool
spec:
  blocks:
  - cidr: 192.168.56.20/28
---
apiVersion: cilium.io/v2alpha1
kind: CiliumL2AnnouncementPolicy
metadata:
  name: default
spec:
  interfaces:
  - eth1
  loadBalancerIPs: true
CILIUM_LB_CFG

      echo "[INFO] Allow addons to run on control-plane (single-node bootstrap)"
      # When only the control-plane exists, default NoSchedule taint can block core addons.
      # We tolerate both legacy ("master") and current ("control-plane") taint keys.
      ADDON_TOLERATIONS_MERGE='{"spec":{"template":{"spec":{"tolerations":[{"key":"node-role.kubernetes.io/control-plane","operator":"Exists","effect":"NoSchedule"},{"key":"node-role.kubernetes.io/master","operator":"Exists","effect":"NoSchedule"}]}}}}'

      echo "[INFO] Install metrics-server"
      if ! kubectl -n kube-system get deploy metrics-server >/dev/null 2>&1; then
        kubectl apply -f https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml
        kubectl -n kube-system patch deploy metrics-server --type=merge -p "$ADDON_TOLERATIONS_MERGE" >/dev/null || true
        kubectl -n kube-system patch deploy metrics-server --type='json' -p='[{"op": "add", "path": "/spec/template/spec/containers/0/args/-", "value": "--kubelet-insecure-tls"}]' >/dev/null || true
        if ! kubectl -n kube-system rollout status deploy metrics-server --timeout=180s; then
          echo "[WARN] metrics-server rollout did not complete within timeout; check 'kubectl -n kube-system get pods -l k8s-app=metrics-server'"
        fi
      else
        echo "[INFO] metrics-server already installed"
        kubectl -n kube-system patch deploy metrics-server --type=merge -p "$ADDON_TOLERATIONS_MERGE" >/dev/null || true
        kubectl -n kube-system patch deploy metrics-server --type='json' -p='[{"op": "add", "path": "/spec/template/spec/containers/0/args/-", "value": "--kubelet-insecure-tls"}]' >/dev/null || true
      fi

      echo "[INFO] Install Argo CD"
      if ! kubectl get ns argocd >/dev/null 2>&1; then
        kubectl create namespace argocd
      fi

      if ! kubectl -n argocd get deploy argocd-server >/dev/null 2>&1; then
        # Pin Argo CD to a specific version to avoid oversized CRD annotations in some "stable" bundles.
        if ! kubectl apply -n argocd -f https://raw.githubusercontent.com/argoproj/argo-cd/v3.3.4/manifests/install.yaml; then
          echo "[ERROR] Failed to apply Argo CD manifests (v3.3.4). Check CRD limits or update manifest URL."
        fi
      else
        echo "[INFO] Argo CD already installed"
      fi

      echo "[INFO] Disable ArgoCD TLS (insecure mode) so Cilium ingress handles HTTP"
      kubectl -n argocd patch deployment argocd-server --type=json \
        -p='[{"op":"add","path":"/spec/template/spec/containers/0/args/-","value":"--insecure"}]' >/dev/null || true

      echo "[INFO] Expose Argo CD server via Ingress"
      cat <<'ARGOCD_INGRESS' | kubectl apply -f -
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: argocd-server-ingress
  namespace: argocd
  annotations:
    kubernetes.io/ingress.class: cilium
spec:
  rules:
  - host: argocd.local
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: argocd-server
            port:
              number: 80
ARGOCD_INGRESS

      echo "[INFO] Wait for Argo CD server rollout (best-effort)"
      if ! kubectl -n argocd rollout status deploy/argocd-server --timeout=180s; then
        echo "[WARN] Argo CD server rollout did not complete within timeout; check 'kubectl -n argocd get pods'"
      fi

      until kubectl -n argocd get secret argocd-secret >/dev/null 2>&1; do
        echo "[INFO] Waiting for argocd-secret..."
        sleep 5
      done

      echo "[INFO] Set Argo CD admin password"
      # Generate bcrypt hash for password and patch argocd-secret
      ARGOCD_ADMIN_HASH=$(htpasswd -nbBC 10 admin #{ARGOCD_ADMIN_PASSWORD} | cut -d: -f2 | sed 's/\$2y\$/\$2a\$/')
      if [ -n "$ARGOCD_ADMIN_HASH" ]; then
        kubectl -n argocd patch secret argocd-secret \
          -p "{\"stringData\": {\"admin.password\": \"$ARGOCD_ADMIN_HASH\", \"admin.passwordMtime\": \"$(date +%FT%T%Z)\"}}" >/dev/null || true
      else
        echo "[WARN] Failed to generate Argo CD admin password hash"
      fi

      echo "[INFO] Generate join command"
      kubeadm token create --print-join-command >/vagrant/join.sh
      chmod +x /vagrant/join.sh

      echo "[INFO] Cluster nodes"
      kubectl get nodes -o wide || true

      echo "[INFO] Copying and customizing kubeconfig"
      cp /home/vagrant/.kube/config /vagrant/vagrant.yaml
      chown 1000:1000 /vagrant/vagrant.yaml
      chmod 644 /vagrant/vagrant.yaml

      export KUBECONFIG_HOST=/vagrant/vagrant.yaml

      sed -i 's,server: https://.*:6443,server: https://192.168.56.10:6443,g' $KUBECONFIG_HOST

      kubectl --kubeconfig=$KUBECONFIG_HOST config set-context vagrant \
        --cluster=kubernetes \
        --user=kubernetes-admin

      kubectl --kubeconfig=$KUBECONFIG_HOST config delete-context kubernetes-admin@kubernetes
      kubectl --kubeconfig=$KUBECONFIG_HOST config use-context vagrant

      echo "[INFO] Kubeconfig is ready. Context name: vagrant"
    SHELL

    WORKER_SCRIPT = <<-SHELL
      #!/usr/bin/env bash
      set -euxo pipefail

      if [ -f /etc/kubernetes/kubelet.conf ]; then
        echo "[INFO] Worker already joined to cluster"
        exit 0
      fi

      echo "[INFO] Wait for join script"
      until [ -f /vagrant/join.sh ]; do
        sleep 5
      done

      echo "[INFO] Join node to cluster"
      until bash /vagrant/join.sh; do
        echo "[WARN] Join failed, retry in 10 seconds"
        sleep 10
      done
    SHELL

    # MASTER NODE
    config.vm.define "master" do |master|
      master.vm.hostname = "k8s-master"
      master.vm.network "private_network", ip: "192.168.56.10"

      master.vm.provider "virtualbox" do |v|
        v.name = "k8s-master"
        v.memory = MASTER_MEMORY
        v.cpus = MASTER_CPUS
      end

      master.vm.provision "shell", inline: COMMON_SCRIPT
      master.vm.provision "shell", inline: MASTER_SCRIPT
    end

    # WORKER NODES
    (1..2).each do |i|
      config.vm.define "worker-#{i}" do |worker|
        worker.vm.hostname = "k8s-worker-#{i}"
        worker.vm.network "private_network", ip: "192.168.56.#{10 + i}"

        worker.vm.provider "virtualbox" do |v|
          v.name = "k8s-worker-#{i}"
          v.memory = WORKER_MEMORY
          v.cpus = WORKER_CPUS
        end

        worker.vm.provision "shell", inline: COMMON_SCRIPT
        worker.vm.provision "shell", inline: WORKER_SCRIPT
      end
    end
  end